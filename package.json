{
  "name": "mesa-servicio",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter portal dev\" \"pnpm --filter api dev\"",
    "dev:portal": "pnpm --filter portal dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter shared build && pnpm --filter portal build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["unrs-resolver", "esbuild", "sharp", "@next/swc-win32-x64-msvc"]
  }
}
